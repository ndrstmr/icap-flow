{
  "name": "ndrstmr/icap-flow",
  "type": "library",
  "description": "State-of-the-art, async-ready ICAP client for PHP.",
  "license": "EUPL-1.2",
  "authors": [
    {
      "name": "ndrstmr",
      "homepage": "https://github.com/ndrstmr",
      "role": "Developer"
    }
  ],
  "require": {
    "php": "^8.4",
    "amphp/socket": "^2.3",
    "psr/log": "^3.0",
    "revolt/event-loop": "^1.0"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.75",
    "mockery/mockery": "^1.6",
    "pestphp/pest": "^3.8",
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "^11.2",
    "roave/security-advisories": "dev-latest"
  },
  "autoload": {
    "psr-4": {
      "Ndrstmr\\Icap\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Ndrstmr\\Icap\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "pest --testsuite=Unit",
    "test:integration": "pest --testsuite=Integration",
    "test:all": "pest",
    "stan": "phpstan analyse",
    "cs-check": "php-cs-fixer fix --dry-run --diff",
    "cs-fix": "php-cs-fixer fix",
    "mutation": "pest --mutate --testsuite=Unit --parallel --covered-only --min=65"
  },
  "config": {
    "sort-packages": true,
    "platform": {
      "php": "8.4.0"
    },
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  }
}
