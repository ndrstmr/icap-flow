{
    $schema: "vendor/infection/infection/resources/schema.json",
    source: {
        directories: [
            "src",
        ],
    },
    timeout: 30,
    logs: {
        text: "build/infection.log",
        summary: "build/infection-summary.log",
    },
    // MSI (Mutation Score Indicator) gates — values are conservative for
    // the initial introduction; they can be ratcheted up in M4.5-follow-up
    // once the integration suite lands and adds coverage for the
    // transports and preview continuation paths.
    minMsi: 65,
    minCoveredMsi: 75,
    // Pest 3 generates PHPUnit-compatible test classes at runtime, so
    // Infection drives the underlying PHPUnit runner. The
    // testFrameworkOptions restrict execution to the Unit suite so
    // mutants don't exercise the skip-on-missing-env Integration tests.
    testFramework: "phpunit",
    testFrameworkOptions: "--testsuite=Unit",
    mutators: {
        "@default": true,
    },
}
